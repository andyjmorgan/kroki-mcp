{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.AspNetCore.HttpLogging": "Information",
        "System.Net.Http.HttpClient": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "Kroki": {
    "DispatcherUrl": "http://kroki-dispatcher.kroki.svc.cluster.local:8000",
    "Timeout": "00:00:30",
    "MaxSourceBytes": 262144
  },
  "BlobStore": {
    "Endpoint": "http://seaweedfs.kroki-mcp.svc.cluster.local:8333",
    "Bucket": "diagrams",
    "PublicBaseUrl": "https://kroki-cdn.donkeywork.dev",
    "RetentionDays": 30
  }
}
